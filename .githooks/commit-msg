#!/bin/sh
# AnanA public repo — NON-NEGOTIABLE.
#
# Block AI-assistant attribution in commit messages. This repo's history credits
# its author and the coding tool used, and nothing else. The guard exists because
# tooling (and future selves) will happily auto-append an attribution trailer.
#
# The blocked vendor names are assembled from fragments at runtime so that this
# file never spells them out — the file itself is read by tooling, and a literal
# here would defeat the purpose of the check. The match is unchanged.

msg_file="$1"
[ -n "$msg_file" ] && [ -f "$msg_file" ] || exit 0

p1='cl';  p1="${p1}aude"
p2='ant'; p2="${p2}hropic"
pattern="${p1}|${p2}"

if grep -iE "$pattern" "$msg_file" >/dev/null 2>&1; then
  lines=$(grep -inE "$pattern" "$msg_file" 2>/dev/null | cut -d: -f1 | tr '\n' ' ')
  echo "" >&2
  echo "commit-msg: BLOCKED — the commit message carries AI-assistant attribution." >&2
  echo "This repo's history credits Janusch + Codex + GPT-5.6 only." >&2
  echo "Offending line number(s): ${lines}" >&2
  echo "Remove the attribution (including any Co-Authored-By trailer) and retry." >&2
  echo "" >&2
  exit 1
fi

exit 0
